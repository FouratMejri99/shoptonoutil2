# ===============================================
# Backend Environment Variables (Render)
# ===============================================
# Copy this file to .env and fill in the values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-xx.pooler.supabase.com:6543/postgres

# Authentication
JWT_SECRET=your-secure-random-string-min-32-chars
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://your-oauth-server.com
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your-open-id

# Supabase (for storage, auth, etc.)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-access-token
SUPABASE_STORAGE_BUCKET=public-assets

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# CORS - Allow frontend domains (comma-separated)
ALLOWED_ORIGINS=https://app.solupedia.com,https://www.solupedia.com

# Node Environment
NODE_ENV=production

# Build Settings
# No build-specific env vars needed
