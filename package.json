    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-map-gl": "^7.1.7",
    "@types/react-quill": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/ui": "^2.1.1",
