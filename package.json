    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.33.0",
    "embla-carousel-react": "^8.3.0",
    "input-otp": "^1.2.4",
    "jose": "^5.9.3",
    "katex": "^0.16.11",
    "lucide-react": "^0.453.0",
    "marked": "^14.1.2",
    "mermaid": "^11.3.0",
    "next-themes": "^0.4.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.68.4",
    "postgres": "^3.4.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
